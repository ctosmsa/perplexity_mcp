{
  "version": 2,
  "builds": [
    {
      "src": "perplexity_mcp/http_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/mcp",
      "dest": "perplexity_mcp/http_server.py"
    },
    {
      "src": "/(.*)",
      "dest": "perplexity_mcp/http_server.py"
    }
  ]
}